import java.util.*;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int t=sc.nextInt();
        sc.nextLine();
        while(t>0){
            t--;
            String k=sc.nextLine();
            String h="";
            for(int i=1;i<=k.length();i++){
                h+=k.substring(0, i);
            }
            System.out.println(h);
        }
        sc.close();
    }
}
