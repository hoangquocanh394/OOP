import java.util.Scanner;
class Employee{
    private String name;
    private double salary;
    public Employee(String name,double salary){
        this.name=name;
        this.salary=salary;
    }
    public String getName(){
        return this.name;
    }
    public double getSalary(){
        return this.salary;
    }
    public void setName(String name) {
        this.name = name;
    }
    public void setSalary(double salary) {
        this.salary = salary;
    }
    public void getinfo(){
        
    }
    public double calculateSalary(){
        return this.salary;
    }
}
class FullTimeEmployee extends Employee{
    private double bonus;
    public FullTimeEmployee(String name,double salary,double bonus){
        super(name,salary);
        this.bonus=bonus;
    }
    public double calculateSalary(){
        return this.getSalary()+this.bonus;
    }
    public void getinfo(){
        System.out.println("Loại: FullTime");
        System.out.println("Họ tên: "+this.getName());
        System.out.println("Lương cơ bản: "+this.getSalary());
        System.out.println("Thưởng: "+this.bonus);
        System.out.println("=> Lương thực nhận: "+this.calculateSalary());
    }
}
class PartTimeEmployee extends Employee{
    private int hoursWorked;
    private double hourlyRate;
    public PartTimeEmployee(String name,int hoursWorked,double hourlyRate){
        super(name,0);
        this.hoursWorked=hoursWorked;
        this.hourlyRate=hourlyRate;
    }
    public double calculateSalary(){
        return this.hourlyRate*this.hoursWorked;
    }
    public void getinfo(){
        System.out.println("Loại: PartTime");
        System.out.println("Họ tên: "+this.getName());
        System.out.println("Số giờ làm việc: "+this.hoursWorked+" giờ");
        System.out.println("Tiền công mỗi giờ: "+this.hourlyRate);
        System.out.println("=> Lương thực nhận: "+this.calculateSalary());
    }
}
public class Main {

    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        System.out.println("--- Thông tin nhân viên ---");
        for(int i=0;i<2;i++){
            String a=sc.nextLine();
            String b=sc.nextLine();
            if(a.equals("FullTime")){
                double c=sc.nextDouble();
                double d=sc.nextDouble();
                FullTimeEmployee f=new FullTimeEmployee(b,c,d);
                f.getinfo();
            }else{
                int c=sc.nextInt();
                double d=sc.nextDouble();
                PartTimeEmployee p=new PartTimeEmployee(b,c,d);
                p.getinfo();
            }
            sc.nextLine();
            System.out.println("");
        }
        sc.close();
    }
}
